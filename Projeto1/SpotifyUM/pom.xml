<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.example</groupId>
    <artifactId>SpotifyUM</artifactId>
    <version>1.0-SNAPSHOT</version>

    <properties>
        <maven.compiler.source>8</maven.compiler.source>
        <maven.compiler.target>8</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <junit.version>5.8.2</junit.version>
        <jqwik.version>1.7.4</jqwik.version>
        <evosuite.version>1.0.3</evosuite.version>
        <evosuite.cuts>org.Model.SpotifUM,org.Model.Album.Album,org.Model.Music.Music</evosuite.cuts>
        <evosuite.timeInMinutesPerClass>1</evosuite.timeInMinutesPerClass>
        <evosuite.numberOfCores>4</evosuite.numberOfCores>
        <jacoco.version>0.8.12</jacoco.version>
        <pitest.version>1.9.11</pitest.version>
        <pitest.junit5.version>1.0.0</pitest.junit5.version>
    </properties>

    <repositories>
        <repository>
            <id>evosuite</id>
            <url>https://www.evosuite.org/m2</url>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>evosuite</id>
            <url>https://www.evosuite.org/m2</url>
        </pluginRepository>
    </pluginRepositories>

    <dependencies>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>${maven.compiler.source}</source>
                    <target>${maven.compiler.target}</target>
                    <testExcludes>
                        <testExclude>**/*ESTest.java</testExclude>
                        <testExclude>**/*ESTest_scaffolding.java</testExclude>
                    </testExcludes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.2.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>org.App</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>2.22.2</version>
                <configuration>
                    <!-- Disable module path to work smoothly with JUnit 5 -->
                    <useModulePath>false</useModulePath>
                    <argLine>${jacocoArgLine} --add-opens java.desktop/java.awt=ALL-UNNAMED --add-opens java.base/java.net=ALL-UNNAMED --add-exports java.base/sun.net.util=ALL-UNNAMED</argLine>
                    <includes>
                        <include>**/*Test.java</include>
                        <include>**/*Tests.java</include>
                        <include>**/*TestCase.java</include>
                    </includes>
                    <excludes>
                        <!-- EvoSuite-generated tests in this repo are currently stale and fail at runtime -->
                        <exclude>**/*ESTest.java</exclude>
                        <exclude>**/*ESTest_scaffolding.java</exclude>
                    </excludes>
                </configuration>
            </plugin>

            <!-- Coverage reports (run with: mvn verify) -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>${jacoco.version}</version>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                        <configuration>
                            <propertyName>jacocoArgLine</propertyName>
                        </configuration>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Mutation testing (run with: mvn org.pitest:pitest-maven:mutationCoverage) -->
            <plugin>
                <groupId>org.pitest</groupId>
                <artifactId>pitest-maven</artifactId>
                <version>${pitest.version}</version>
                <configuration>
                    <threads>4</threads>
                    <verbose>false</verbose>
                    <timestampedReports>false</timestampedReports>
                    <outputFormats>
                        <param>HTML</param>
                        <param>XML</param>
                    </outputFormats>
                    <jvmArgs>
                        <param>-Djava.awt.headless=true</param>
                        <param>--add-opens=java.desktop/java.awt=ALL-UNNAMED</param>
                        <param>--add-opens=java.base/java.net=ALL-UNNAMED</param>
                        <param>--add-exports=java.base/sun.net.util=ALL-UNNAMED</param>
                    </jvmArgs>
                    <!-- Focus mutation on business logic; exclude UI menus -->
                    <targetClasses>
                        <param>org.Model.*</param>
                        <param>org.Controller.*</param>
                        <param>org.Utils.*</param>
                        <param>org.Exceptions.*</param>
                    </targetClasses>
                    <excludedClasses>
                        <param>org.View.*</param>
                        <param>org.App</param>
                    </excludedClasses>
                    <excludedTestClasses>
                        <param>org.View.*</param>
                        <param>*ESTest*</param>
                        <param>*ESTest_scaffolding*</param>
                    </excludedTestClasses>
                </configuration>
                <dependencies>
                    <dependency>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-junit5-plugin</artifactId>
                        <version>${pitest.junit5.version}</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>tests-junit5</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <dependencies>
                <dependency>
                    <groupId>org.junit.jupiter</groupId>
                    <artifactId>junit-jupiter-api</artifactId>
                    <version>${junit.version}</version>
                    <scope>test</scope>
                </dependency>
                <dependency>
                    <groupId>net.jqwik</groupId>
                    <artifactId>jqwik</artifactId>
                    <version>${jqwik.version}</version>
                    <scope>test</scope>
                </dependency>
                <dependency>
                    <groupId>org.mockito</groupId>
                    <artifactId>mockito-core</artifactId>
                    <version>4.11.0</version>
                    <scope>test</scope>
                </dependency>
                <dependency>
                    <groupId>org.junit.jupiter</groupId>
                    <artifactId>junit-jupiter-engine</artifactId>
                    <version>${junit.version}</version>
                    <scope>test</scope>
                </dependency>
            </dependencies>
        </profile>

        <profile>
            <id>evosuite-generate</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.evosuite.plugins</groupId>
                        <artifactId>evosuite-maven-plugin</artifactId>
                        <version>${evosuite.version}</version>
                        <configuration>
                            <cuts>${evosuite.cuts}</cuts>
                            <projectCP>${project.build.outputDirectory}</projectCP>
                            <timeInMinutesPerClass>${evosuite.timeInMinutesPerClass}</timeInMinutesPerClass>
                            <numberOfCores>${evosuite.numberOfCores}</numberOfCores>
                            <assertions>true</assertions>
                        </configuration>
                        <executions>
                            <execution>
                                <id>evosuite-generate-tests</id>
                                <phase>generate-test-sources</phase>
                                <goals>
                                    <goal>generate</goal>
                                </goals>
                            </execution>
                            <execution>
                                <id>evosuite-export-tests</id>
                                <phase>process-test-sources</phase>
                                <goals>
                                    <goal>export</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

    </profiles>
</project>